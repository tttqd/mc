{
  "file": "/data/settings.yml",
  "ops": [
    {
      "$set": {
        "path": "$.infoForwarding.type",
        "value": "MODERN"
      }
    },
    {
      "$set": {
        "path": "$.infoForwarding.secret",
        "value": "${CFG_FORWARDING_SECRET}"
      }
    },
    {
      "$set": {
        "path": "$.maxPlayers",
        "value": -1
      }
    },
    {
      "$set": {
        "path": "$.brandName.enable",
        "value": false
      }
    },
    {
      "$set": {
        "path": "$.joinMessage.enable",
        "value": false
      }
    },
    {
      "$set": {
        "path": "$.bossBar.enable",
        "value": false
      }
    },
    {
      "$set": {
        "path": "$.title.enable",
        "value": false
      }
    }
  ]
}
