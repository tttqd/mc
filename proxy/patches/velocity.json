{
  "file": "/server/velocity.toml",
  "ops": [
    {
      "$set": {
        "path": "$.online-mode",
        "value": false
      }
    },
    {
      "$set": {
        "path": "$.player-info-forwarding-mode",
        "value": "modern"
      }
    },
    {
      "$set": {
        "path": "$.servers",
        "value": {
          "smp": "smp:25565",
          "try": ["smp"]
        }
      }
    },
    {
      "$set": {
        "path": "$['forced-hosts']",
        "value": {
          "localhost": ["smp"]
        }
      }
    },
    {
      "$set": {
        "path": "$.advanced['tcp-fast-open']",
        "value": true
      }
    }
  ]
}
