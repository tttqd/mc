{
  "file": "/server/velocity.toml",
  "ops": [
    {
      "$set": {
        "path": "$.network-compression-threshold",
        "value": -1
      }
    },
    {
      "$set": {
        "path": "$.online-mode",
        "value": false
      }
    },
    {
      "$set": {
        "path": "$.player-info-forwarding-mode",
        "value": "modern"
      }
    },
    {
      "$set": {
        "path": "$.servers",
        "value": {
          "lobby": "smp:25565",
          "limbo": "limbo:25565",
          "try": ["lobby", "limbo"]
        }
      }
    },
    {
      "$set": {
        "path": "$['forced-hosts']",
        "value": {
          "localhost": ["lobby"]
        }
      }
    },
    {
      "$set": {
        "path": "$.advanced['tcp-fast-open']",
        "value": true
      }
    }
  ]
}
